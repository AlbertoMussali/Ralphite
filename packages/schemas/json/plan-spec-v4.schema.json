{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralphite.dev/schemas/plan-spec-v4.json",
  "title": "PlanSpecV4",
  "type": "object",
  "required": ["version", "plan_id", "name", "run", "constraints", "agents", "tasks"],
  "properties": {
    "version": {"type": "integer", "const": 4},
    "plan_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "workspace": {
      "type": "object",
      "properties": {"root": {"type": ["string", "null"]}},
      "additionalProperties": false
    },
    "materials": {
      "type": "object",
      "properties": {
        "autodiscover": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "path": {"type": "string"},
            "include_globs": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "includes": {"type": "array", "items": {"type": "string"}},
        "uploads": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "run": {
      "type": "object",
      "required": ["pre_orchestrator", "post_orchestrator"],
      "properties": {
        "pre_orchestrator": {
          "type": "object",
          "required": ["enabled", "agent"],
          "properties": {
            "enabled": {"type": "boolean"},
            "agent": {"type": "string"}
          },
          "additionalProperties": false
        },
        "post_orchestrator": {
          "type": "object",
          "required": ["enabled", "agent"],
          "properties": {
            "enabled": {"type": "boolean"},
            "agent": {"type": "string"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_runtime_seconds": {"type": "integer", "minimum": 1},
        "max_total_steps": {"type": "integer", "minimum": 1},
        "max_cost_usd": {"type": "number", "minimum": 0},
        "fail_fast": {"type": "boolean"},
        "max_parallel": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "provider", "model"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string", "enum": ["worker", "orchestrator_pre", "orchestrator_post"]},
          "provider": {"type": "string"},
          "model": {"type": "string"},
          "system_prompt": {"type": "string"},
          "tools_allow": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "completed"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "completed": {"type": "boolean"},
          "description": {"type": "string"},
          "parallel_group": {"type": "integer", "minimum": 0},
          "deps": {"type": "array", "items": {"type": "string"}},
          "agent": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "format"],
            "properties": {
              "id": {"type": "string"},
              "format": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
