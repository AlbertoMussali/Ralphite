{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralphite.dev/schemas/plan-spec-v2.json",
  "title": "PlanSpecV2",
  "type": "object",
  "required": ["version", "plan_id", "name", "task_source", "agent_profiles", "execution_structure"],
  "properties": {
    "version": {"type": "integer", "const": 2},
    "plan_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "workspace": {
      "type": "object",
      "properties": {"root": {"type": ["string", "null"]}},
      "additionalProperties": false
    },
    "materials": {
      "type": "object",
      "properties": {
        "autodiscover": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean"},
            "path": {"type": "string"},
            "include_globs": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "includes": {"type": "array", "items": {"type": "string"}},
        "uploads": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "task_source": {
      "type": "object",
      "required": ["kind", "path", "parser_version"],
      "properties": {
        "kind": {"type": "string", "enum": ["markdown_checklist"]},
        "path": {"type": "string", "minLength": 1},
        "parser_version": {"type": "integer", "const": 2}
      },
      "additionalProperties": false
    },
    "agent_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "provider", "model"],
        "properties": {
          "id": {"type": "string"},
          "role": {"type": "string", "enum": ["worker", "orchestrator_pre", "orchestrator_post"]},
          "provider": {"type": "string"},
          "model": {"type": "string"},
          "system_prompt": {"type": "string"},
          "tools_allow": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "execution_structure": {
      "type": "object",
      "required": ["phases"],
      "properties": {
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "workers"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "label": {"type": "string"},
              "pre_orchestrator": {
                "type": "object",
                "required": ["enabled", "agent_profile_id"],
                "properties": {
                  "enabled": {"type": "boolean"},
                  "agent_profile_id": {"type": "string"}
                },
                "additionalProperties": false
              },
              "workers": {
                "type": "object",
                "properties": {
                  "sequential_before": {"type": "array", "items": {"type": "string"}},
                  "parallel": {"type": "array", "items": {"type": "string"}},
                  "sequential_after": {"type": "array", "items": {"type": "string"}}
                },
                "additionalProperties": false
              },
              "post_orchestrator": {
                "type": "object",
                "required": ["enabled", "agent_profile_id"],
                "properties": {
                  "enabled": {"type": "boolean"},
                  "agent_profile_id": {"type": "string"}
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "properties": {
        "max_runtime_seconds": {"type": "integer", "minimum": 1},
        "max_total_steps": {"type": "integer", "minimum": 1},
        "max_cost_usd": {"type": "number", "minimum": 0},
        "fail_fast": {"type": "boolean"},
        "max_parallel": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "object",
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "format"],
            "properties": {
              "id": {"type": "string"},
              "format": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
