{
  "name": "ralphite-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev:web": "pnpm --filter @ralphite/web dev",
    "dev:tui": "uv run ralphite tui",
    "build:web": "pnpm --filter @ralphite/web build",
    "lint:web": "pnpm --filter @ralphite/web lint",
    "check": "uv run ralphite check --full"
  }
}
