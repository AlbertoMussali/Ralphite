{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ralphite.dev/schemas/cli-output-v1.json",
  "title": "CliOutputV1",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "ok",
    "status",
    "run_id",
    "exit_code",
    "issues",
    "next_actions",
    "data"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "cli-output.v1"
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "exit_code": {
      "type": "integer"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
